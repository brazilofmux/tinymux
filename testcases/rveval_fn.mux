#
# Test Case #75 - Tier 2 chain: strlen(strcat(rand(1),hello)) = 6.
# strcat("0","hello")="0hello", strlen("0hello")=6.
#
&tr.tc075 test_rveval_fn=
  @if strmatch(
        setr(0, rveval(strlen(strcat(rand(1),hello)))),
        6
      )=
  {
    @log smoke=TC075: rveval Tier2 strlen(strcat(rand(1),hello))=6. Succeeded.;
    @trig me/tr.done
  },
  {
    @log smoke=TC075: rveval Tier2 strlen(strcat(rand(1),hello))=6. Failed (%q0).;
    @trig me/tr.done
  }
-
