#
# MEMBER - word membership in lists.
#
# (TC019's original call had member()'s arguments reversed — it is
# member(list, word) — so it asserted the error value 0.  Fixed.)
&tr.tc019 test_jit_fold_parity_fn=
  @if strmatch(sha1(member(alpha beta gamma delta,gamma)),77DE68DAECD823BABBB58EDB1C8E14D7106E83BB)=
  {
    @log smoke=TC019: member() found parity. Succeeded.
  },
  {
    @log smoke=TC019: member() found parity. Failed.
  }
-
&tr.tc020 test_jit_fold_parity_fn=
  @if strmatch(sha1(member(alpha beta gamma,missing)),B6589FC6AB0DC82CF12099D1C2D40AB994E8410C)=
