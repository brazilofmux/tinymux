#
# jit_fold_parity_fn.mux - Parity tests for try_fold constant folding.
#
# Each expression is evaluated on the production route (bracket-free
# condition, so the JIT/fold path handles it with jit_eval_brackets on
# by default) and asserted against an AST-canonical sha1 constant
# captured in an explicit toggle-off workspace.  Because the smoke
# suite runs under both toggles, every constant is checked on the JIT
# route AND the AST route each cycle — stronger than the older live
# asteval({...}) comparison, which passes whenever both routes drift
# together (see #987 for the bracket-content pre-evaluation footgun
# that motivated the audit of this pattern).
#
# These tests target edge cases that could expose mismatches between
# the co_* Ragel wrappers used in try_fold, the tier2 blob wrappers,
# and the runtime fun_* implementations.
#
@create test_jit_fold_parity_fn
-
@set test_jit_fold_parity_fn=INHERIT QUIET
-
&tr.tc000 test_jit_fold_parity_fn=
  @log smoke=Beginning JIT fold parity test cases.
-
#
# STRLEN - grapheme clusters, not bytes or code points.
#
&tr.tc001 test_jit_fold_parity_fn=
  @if strmatch(sha1(strlen(hello)),AC3478D69A3C81FA62E60F5C3696165A4E5E6AC4)=
  {
    @log smoke=TC001: strlen() ASCII parity. Succeeded.
  },
  {
    @log smoke=TC001: strlen() ASCII parity. Failed.
  }
-
&tr.tc002 test_jit_fold_parity_fn=
  @if strmatch(sha1(strlen()),B6589FC6AB0DC82CF12099D1C2D40AB994E8410C)=
  {
    @log smoke=TC002: strlen() empty parity. Succeeded.
  },
  {
    @log smoke=TC002: strlen() empty parity. Failed.
  }
-
#
# WORDS - word counting with default and custom delimiters.
#
&tr.tc003 test_jit_fold_parity_fn=
  @if strmatch(sha1(words(the quick brown fox)),1B6453892473A467D07372D45EB05ABC2031647A)=
  {
    @log smoke=TC003: words() basic parity. Succeeded.
  },
  {
    @log smoke=TC003: words() basic parity. Failed.
  }
-
&tr.tc004 test_jit_fold_parity_fn=
  @if strmatch(sha1(words()),B6589FC6AB0DC82CF12099D1C2D40AB994E8410C)=
  {
    @log smoke=TC004: words() empty parity. Succeeded.
  },
  {
    @log smoke=TC004: words() empty parity. Failed.
  }
-
&tr.tc005 test_jit_fold_parity_fn=
  @if strmatch(sha1(words(a-b-c-d,-)),1B6453892473A467D07372D45EB05ABC2031647A)=
  {
    @log smoke=TC005: words() custom delim parity. Succeeded.
  },
  {
    @log smoke=TC005: words() custom delim parity. Failed.
  }
-
