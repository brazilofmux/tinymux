#
# jit_fold_parity_fn.mux - Parity tests for try_fold constant folding.
#
# Each test evaluates an expression normally (JIT/fold path) and via
# asteval() (AST-only path).  Results must match byte-for-byte.
# SHA1 is used when results may contain special characters.
#
# These tests specifically target edge cases that could expose
# mismatches between the co_* Ragel wrappers used in try_fold
# and the runtime fun_* implementations.
#
@create test_jit_fold_parity_fn
-
@set test_jit_fold_parity_fn=INHERIT QUIET
-
&tr.tc000 test_jit_fold_parity_fn=
  @log smoke=Beginning JIT fold parity test cases.
-
#
# STRLEN - grapheme clusters, not bytes or code points.
#
&tr.tc001 test_jit_fold_parity_fn=
  @if strmatch(
        setr(0,[strlen(hello)]),
        setr(1,[asteval({strlen(hello)})])
      )=
  {
    @log smoke=TC001: strlen() ASCII parity. Succeeded.
  },
  {
    @log smoke=TC001: strlen() ASCII parity. Failed (%q0 vs %q1).
  }
-
&tr.tc002 test_jit_fold_parity_fn=
  @if strmatch(
        setr(0,[strlen()]),
        setr(1,[asteval({strlen()})])
      )=
  {
    @log smoke=TC002: strlen() empty parity. Succeeded.
  },
  {
    @log smoke=TC002: strlen() empty parity. Failed (%q0 vs %q1).
  }
-
#
# WORDS - word counting with default and custom delimiters.
#
&tr.tc003 test_jit_fold_parity_fn=
  @if strmatch(
        setr(0,[words(the quick brown fox)]),
        setr(1,[asteval({words(the quick brown fox)})])
      )=
  {
    @log smoke=TC003: words() basic parity. Succeeded.
  },
  {
    @log smoke=TC003: words() basic parity. Failed (%q0 vs %q1).
  }
-
&tr.tc004 test_jit_fold_parity_fn=
  @if strmatch(
        setr(0,[words()]),
