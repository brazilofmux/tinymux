-
&tr.tc050 test_jit_fold_parity_fn=
  @if strmatch(version(),MUX *)=
  {
    @log smoke=TC050: version() parity. Succeeded.;
    @trig me/tr.done
  },
  {
    @log smoke=TC050: version() parity. Failed.;
    @trig me/tr.done
  }
-
&tr.done test_jit_fold_parity_fn=
  @log smoke=End JIT fold parity test cases.;
  @notify smoke
-
drop test_jit_fold_parity_fn
-
