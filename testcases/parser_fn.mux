-
#
# Test Case #37 - Edge probe: malformed %q angle with backslash escape.
#
&tr.tc037 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({A%q<bad\escape})]
          )
        ),
        setr(1,sha1(
            [eval({A%q<bad\escape})]
          )
        )
      )=
  {
    @log smoke=TC037: edge malformed pct-q + backslash parity. Succeeded.
