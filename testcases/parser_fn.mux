#
# Test Case #35 - Edge probe: malformed %= angle with semicolon.
#
&tr.tc035 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({A%=<bad;next})]
          )
        ),
        setr(1,sha1(
            [eval({A%=<bad;next})]
          )
        )
      )=
  {
    @log smoke=TC035: edge malformed pct-equals + semicolon parity. Succeeded.
