-
#
# Test Case #36 - Edge probe: malformed %q angle with open paren.
#
&tr.tc036 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({A%q<bad(foo})]
          )
        ),
        setr(1,sha1(
            [eval({A%q<bad(foo})]
          )
        )
      )=
  {
    @log smoke=TC036: edge malformed pct-q + open paren parity. Succeeded.
