#
# parser_fn.mux - Test Cases for parser behavior.
#
# Tests fundamental expression parser mechanics rather than any
# particular softcode function.  Each test verifies that eval2()
# (AST evaluator) produces the same result as direct evaluation.
#
@create test_parser_fn
-
@set test_parser_fn=INHERIT QUIET
-
#
# Beginning of Test Cases
#
&tr.tc000 test_parser_fn=
  @log smoke=Beginning parser test cases.
-
#
# Test Case #1 - Literal text passes through unchanged.
#
&tr.tc001 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(hello world)]
            [eval2(ABCDEFG)]
            [eval2(1234567890)]
          )
        ),
        setr(1,sha1(
            hello world
            ABCDEFG
            1234567890
          )
        )
      )=
  {
    @log smoke=TC001: parser literal text. Succeeded.
  },
  {
    @log smoke=TC001: parser literal text. Failed (%q0 vs %q1).
  }
-
#
# Test Case #2 - Space compression: runs of spaces compress to one.
#
&tr.tc002 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(a  b)]
            [eval2(a    b)]
            [eval2(a          b)]
          )
        ),
        setr(1,sha1(
            a  b
            a    b
            a          b
          )
        )
      )=
  {
    @log smoke=TC002: parser space compression. Succeeded.
  },
  {
    @log smoke=TC002: parser space compression. Failed (%q0 vs %q1).
  }
-
#
# Test Case #3 - %-substitutions: %b (space), %r (return), %t (tab).
#
&tr.tc003 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(a%bb)]
            [eval2(a%rb)]
            [eval2(a%tb)]
          )
        ),
        setr(1,sha1(
            a%bb
            a%rb
            a%tb
          )
        )
      )=
  {
    @log smoke=TC003: parser pct-subst b/r/t. Succeeded.
  },
  {
    @log smoke=TC003: parser pct-subst b/r/t. Failed (%q0 vs %q1).
  }
-
#
# Test Case #4 - %-substitutions: %# (enactor), %! (executor).
#
# Dbrefs vary per run so we compare eval2 vs direct evaluation.
#
&tr.tc004 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(enactor=%#)]
            [eval2(executor=%!)]
          )
        ),
        setr(1,sha1(
            enactor=%#
            executor=%!
          )
        )
      )=
  {
    @log smoke=TC004: parser pct-subst enactor/executor. Succeeded.
  },
  {
    @log smoke=TC004: parser pct-subst enactor/executor. Failed (%q0 vs %q1).
  }
-
#
# Test Case #5 - %-substitutions: registers %q0-%q9.
#
&tr.tc005 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [setr(1,apple)]
            [setr(2,banana)]
            [eval2(%q1-%q2)]
          )
        ),
        setr(3,sha1(
            [setr(1,apple)]
            [setr(2,banana)]
            %q1-%q2
          )
        )
      )=
  {
    @log smoke=TC005: parser pct-subst registers. Succeeded.
  },
  {
    @log smoke=TC005: parser pct-subst registers. Failed (%q0 vs %q3).
  }
-
#
# Test Case #6 - Eval brackets: [function()] evaluates inline.
#
# Use \[ and \] to pass literal brackets into eval2's argument.
# The outer eval turns \[ into [, then eval2 re-evaluates.
#
&tr.tc006 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(\[add(1,2)\])]
            [eval2(\[mul(3,4)\])]
            [eval2(x\[add(5,6)\]y)]
          )
        ),
        setr(1,sha1(
            [add(1,2)]
            [mul(3,4)]
            x[add(5,6)]y
          )
        )
      )=
  {
    @log smoke=TC006: parser eval brackets. Succeeded.
  },
  {
    @log smoke=TC006: parser eval brackets. Failed (%q0 vs %q1).
  }
-
#
# Test Case #7 - Adjacent eval brackets in sequence.
#
&tr.tc007 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(\[add(1,1)\]\[add(2,2)\]\[add(3,3)\])]
          )
        ),
        setr(1,sha1(
            [add(1,1)][add(2,2)][add(3,3)]
          )
        )
      )=
  {
    @log smoke=TC007: parser adjacent eval brackets. Succeeded.
  },
  {
    @log smoke=TC007: parser adjacent eval brackets. Failed (%q0 vs %q1).
  }
-
#
# Test Case #8 - Brace groups: {text} strips braces, defers eval.
#
&tr.tc008 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(if(1,{hello},{goodbye}))]
            [eval2(if(0,{hello},{goodbye}))]
            [eval2(switch(b,a,{alpha},b,{beta},*,{other}))]
          )
        ),
        setr(1,sha1(
            [if(1,{hello},{goodbye})]
            [if(0,{hello},{goodbye})]
            [switch(b,a,{alpha},b,{beta},*,{other})]
          )
        )
      )=
  {
    @log smoke=TC008: parser brace groups. Succeeded.
  },
  {
    @log smoke=TC008: parser brace groups. Failed (%q0 vs %q1).
  }
-
#
# Test Case #9 - Braces protect commas from argument splitting.
#
&tr.tc009 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(switch(a,a,{result,with,commas},*,other))]
            [eval2(if(1,{x,y,z}))]
          )
        ),
        setr(1,sha1(
            [switch(a,a,{result,with,commas},*,other)]
            [if(1,{x,y,z})]
          )
        )
      )=
  {
    @log smoke=TC009: parser braces protect commas. Succeeded.
  },
  {
    @log smoke=TC009: parser braces protect commas. Failed (%q0 vs %q1).
  }
-
#
# Test Case #10 - Nested braces.
#
&tr.tc010 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(if(1,{outer {inner} text}))]
          )
        ),
        setr(1,sha1(
            [if(1,{outer {inner} text})]
          )
        )
      )=
  {
    @log smoke=TC010: parser nested braces. Succeeded.
  },
  {
    @log smoke=TC010: parser nested braces. Failed (%q0 vs %q1).
  }
-
#
# Test Case #11 - Function calls: basic, nested, zero-arg.
#
&tr.tc011 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(add(1,2))]
            [eval2(add(1,mul(2,3)))]
            [eval2(pi())]
            [eval2(e())]
          )
        ),
        setr(1,sha1(
            [add(1,2)]
            [add(1,mul(2,3))]
            [pi()]
            [e()]
          )
        )
      )=
  {
    @log smoke=TC011: parser function calls. Succeeded.
  },
  {
    @log smoke=TC011: parser function calls. Failed (%q0 vs %q1).
  }
-
#
# Test Case #12 - Deeply nested function calls.
#
&tr.tc012 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(add(1,add(2,add(3,add(4,5)))))]
            [eval2(strlen(ucstr(lcstr(mid(hello world,0,5)))))]
          )
        ),
        setr(1,sha1(
            [add(1,add(2,add(3,add(4,5))))]
            [strlen(ucstr(lcstr(mid(hello world,0,5))))]
          )
        )
      )=
  {
    @log smoke=TC012: parser deep nesting. Succeeded.
  },
  {
    @log smoke=TC012: parser deep nesting. Failed (%q0 vs %q1).
  }
-
#
# Test Case #13 - Commas are literal text outside function calls.
#
# eval2 has maxArgsParsed=1 so commas are literal in its argument.
#
&tr.tc013 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(a,b,c)]
          )
        ),
        setr(1,sha1(
            a,b,c
          )
        )
      )=
  {
    @log smoke=TC013: parser literal commas. Succeeded.
  },
  {
    @log smoke=TC013: parser literal commas. Failed (%q0 vs %q1).
  }
-
#
# Test Case #14 - Empty function arguments.
#
# Test that the parser correctly handles empty arguments in function
# calls.  We use functions whose output is non-empty and contains
# no leading/trailing spaces, so the result survives double evaluation.
#
&tr.tc014 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(if(,yes,no))]
            [eval2(add(,1))]
            [eval2(strlen(cat(a,,b)))]
          )
        ),
        setr(1,sha1(
            [if(,yes,no)]
            [add(,1)]
            [strlen(cat(a,,b))]
          )
        )
      )=
  {
    @log smoke=TC014: parser empty args. Succeeded.
  },
  {
    @log smoke=TC014: parser empty args. Failed (%q0 vs %q1).
  }
-
#
# Test Case #15 - maxArgsParsed: sha1() has maxArgsParsed=1,
# so commas within its argument are literal.
#
&tr.tc015 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(sha1(hello,world))]
            [eval2(sha1(a,b,c))]
          )
        ),
        setr(1,sha1(
            [sha1(hello,world)]
            [sha1(a,b,c)]
          )
        )
      )=
  {
    @log smoke=TC015: parser maxArgsParsed. Succeeded.
  },
  {
    @log smoke=TC015: parser maxArgsParsed. Failed (%q0 vs %q1).
  }
-
#
# Test Case #16 - Unknown function name: paren is literal.
#
&tr.tc016 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(notafunc(x))]
            [eval2(xyzzy(1,2,3))]
          )
        ),
        setr(1,sha1(
            notafunc(x)
            xyzzy(1,2,3)
          )
        )
      )=
  {
    @log smoke=TC016: parser unknown function. Succeeded.
  },
  {
    @log smoke=TC016: parser unknown function. Failed (%q0 vs %q1).
  }
-
#
# Test Case #17 - Mixed nesting: [func({text})] combinations.
#
&tr.tc017 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(if(1,{[add(1,2)]},{[mul(3,4)]}))]
            [eval2(switch(a,a,{[ucstr(hello)]},*,{none}))]
          )
        ),
        setr(1,sha1(
            [if(1,{[add(1,2)]},{[mul(3,4)]})]
            [switch(a,a,{[ucstr(hello)]},*,{none})]
          )
        )
      )=
  {
    @log smoke=TC017: parser mixed nesting. Succeeded.
  },
  {
    @log smoke=TC017: parser mixed nesting. Failed (%q0 vs %q1).
  }
-
#
# Test Case #18 - @@() comment function produces empty output.
#
&tr.tc018 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(@@(this is a comment))]
            [eval2(hello[@@(invisible)]world)]
          )
        ),
        setr(1,sha1(
            [@@(this is a comment)]
            hello[@@(invisible)]world
          )
        )
      )=
  {
    @log smoke=TC018: parser @@ comment. Succeeded.
  },
  {
    @log smoke=TC018: parser @@ comment. Failed (%q0 vs %q1).
  }
-
#
# Test Case #19 - NOEVAL functions: switchall, caseall.
#
&tr.tc019 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(switchall(a,a,first,a,second,*,star))]
            [eval2(caseall(a,a,first,a,second,*,star))]
          )
        ),
        setr(1,sha1(
            [switchall(a,a,first,a,second,*,star)]
            [caseall(a,a,first,a,second,*,star)]
          )
        )
      )=
  {
    @log smoke=TC019: parser switchall/caseall. Succeeded.
  },
  {
    @log smoke=TC019: parser switchall/caseall. Failed (%q0 vs %q1).
  }
-
#
# Test Case #20 - iter with %i0 substitution.
#
&tr.tc020 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2(iter(X Y Z,%i0))]
            [eval2(iter(10 20 30,[add(%i0,1)]))]
          )
        ),
        setr(1,sha1(
            [iter(X Y Z,%i0)]
            [iter(10 20 30,[add(%i0,1)])]
          )
        )
      )=
  {
    @log smoke=TC020: parser iter with pct-subst. Succeeded.;
  },
  {
    @log smoke=TC020: parser iter with pct-subst. Failed (%q0 vs %q1).;
  }
-
#
# Test Case #21 - Edge probe: unterminated function call text.
#
# Compatibility probe for malformed input.  If eval2 diverges from
# direct eval here, that is a known parser-compatibility choice.
#
&tr.tc021 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [setr(9,EDGE)]
            [eval2({notafunc(%q9})]
          )
        ),
        D1CA511E282F982BB9FB5557A7BE19D2A0E0A547
      )=
  {
    @log smoke=TC021: edge unterminated func-call parity. Succeeded.
  },
  {
    @log smoke=TC021: edge unterminated func-call parity. Failed (%q0).
  }
-
#
# Test Case #22 - Edge probe: unterminated angled %-substitutions.
#
# Probes %q<... / %x<... / %=<... with missing '>'.
# Keep this case even if intentionally unsupported.
#
&tr.tc022 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({%q<missing})]
            [eval2({%x<blue})]
            [eval2({%=<attr})]
          )
        ),
        setr(1,sha1(
            %q<missing
            %x<blue
            %=<attr
          )
        )
      )=
  {
    @log smoke=TC022: edge unterminated angled %-subst parity. Succeeded (possibly fixed).;
  },
  {
    @log smoke=TC022: edge unterminated angled %-subst divergence observed (%q0 vs %q1).;
  }
-
#
# Test Case #23 - Edge probe: unknown simple color escape.
#
# Probe %x? fallback behavior.  Keep this to document chosen behavior.
#
&tr.tc023 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({A%x?B})]
            [eval2({A%c?B})]
          )
        ),
        setr(1,sha1(
            A%x?B
            A%c?B
          )
        )
      )=
  {
    @log smoke=TC023: edge unknown color fallback parity. Succeeded (possibly fixed).;
  },
  {
    @log smoke=TC023: edge unknown color fallback divergence observed (%q0 vs %q1).;
  }
-
#
# Test Case #24 - Edge probe: malformed mix with nested context.
#
# Cross-check malformed pieces inside nested eval context.
#
&tr.tc024 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({prefix [add(1,2)] %q<oops suffix})]
          )
        ),
        5BC915E1A1836B6B2A5D86314A1DD90848D1F581
      )=
  {
    @log smoke=TC024: edge malformed mixed context. Succeeded.
  },
  {
    @log smoke=TC024: edge malformed mixed context. Failed (%q0).
  }
-
#
# Test Case #25 - Edge probe: unterminated outer call with inner bracket eval.
#
&tr.tc025 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({notafunc([add(1,2)]})]
          )
        ),
        320AFE3C83E91C94CA68B8FC478F95DD8F59ED81
      )=
  {
    @log smoke=TC025: edge unterminated call + bracket eval parity. Succeeded.
  },
  {
    @log smoke=TC025: edge unterminated call + bracket eval parity. Failed (%q0).
  }
-
#
# Test Case #26 - Edge probe: nested function text under unterminated outer call.
#
&tr.tc026 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({notafunc(foo(bar(1)})]
          )
        ),
        0A72419F0727120131B818813AC604EF2B6B4402
      )=
  {
    @log smoke=TC026: edge unterminated call + nested parens parity. Succeeded.
  },
  {
    @log smoke=TC026: edge unterminated call + nested parens parity. Failed (%q0).
  }
-
#
# Test Case #27 - Edge probe: comma handling under unterminated outer call.
#
&tr.tc027 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({notafunc(a,b,c})]
          )
        ),
        8FE475F218B6252E71BEE7369015D0A79294D478
      )=
  {
    @log smoke=TC027: edge unterminated call comma handling parity. Succeeded.
  },
  {
    @log smoke=TC027: edge unterminated call comma handling parity. Failed (%q0).
  }
-
#
# Test Case #28 - Edge probe: malformed %q angle forms.
#
&tr.tc028 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({%q<>})]
            [eval2({%q<0>})]
            [eval2({%q<name>>})]
          )
        ),
        091385BE99B45F459A231582D583EC9F3FA3D194
      )=
  {
    @log smoke=TC028: edge malformed pct-q angle forms. Succeeded.
  },
  {
    @log smoke=TC028: edge malformed pct-q angle forms. Failed (%q0).
  }
-
#
# Test Case #29 - Edge probe: malformed color escapes.
#
&tr.tc029 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({A%xB})]
            [eval2({A%x<})]
            [eval2({A%x<noend})]
            [eval2({A%c?B})]
          )
        ),
        68F4E3E995DA3BD32BC4084581F81DD513E1C358
      )=
  {
    @log smoke=TC029: edge malformed color escapes. Succeeded.
  },
  {
    @log smoke=TC029: edge malformed color escapes. Failed (%q0).
  }
-
#
# Test Case #30 - Edge probe: malformed %= forms.
#
&tr.tc030 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({%=})]
            [eval2({%=<})]
            [eval2({%=<0})]
            [eval2({%=<9999>})]
            [eval2({%=<bad attr>})]
          )
        ),
        setr(1,sha1(
            %=
            %=<>
            %=<0
            %=<9999>
            %=<bad attr>
          )
        )
      )=
  {
    @log smoke=TC030: edge malformed %= forms parity. Succeeded (possibly fixed).;
  },
  {
    @log smoke=TC030: edge malformed %= forms divergence observed (%q0 vs %q1).;
  }
-
#
# Test Case #31 - Edge probe: mixed malformed sequence ordering.
#
&tr.tc031 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [setr(3,MIX)]
            [eval2({%q<bad notafunc(%q3 [add(2,2)]})]
          )
        ),
        5F08604B6375DED60CA9001612314F5301C0A80A
      )=
  {
    @log smoke=TC031: edge mixed malformed sequence parity. Succeeded.
  },
  {
    @log smoke=TC031: edge mixed malformed sequence parity. Failed (%q0).
  }
-
#
# Test Case #32 - Edge probe: deep brace/paren mismatch.
#
&tr.tc032 test_parser_fn=
  @if strmatch(
        setr(0,sha1(
            [eval2({{foo(bar},baz)})]
          )
        ),
        setr(1,sha1(
            {foo(bar},baz)
          )
        )
      )=
  {
    @log smoke=TC032: edge deep brace/paren mismatch parity. Succeeded (possibly fixed).;
