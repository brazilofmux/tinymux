#
# sha1_fn.mux - Test Cases for sha1().
#
# Strategy: Exercise examples and test vectors.
#
@create test_sha1_fn
-
@set test_sha1_fn=INHERIT QUIET
-
#
# Beginning of Test Cases
#
&tr.tc000 test_sha1_fn=
  @log smoke=Beginning sha1() test cases.
-
#
# Test Case #1 - Test that help topic examples work.
#
&tr.tc001 test_sha1_fn=
  @if cand(
        strmatch([sha1(abc)], A9993E364706816ABA3E25717850C26C9CD0D89D),
        strmatch([sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq)], 84983E441C3BD26EBAAE4AA1F95129E5E54670F1)
      )=
  {
    @log smoke=TC001: Examples. Succeeded.
  },
  {
    @log smoke=TC001: Examples. Failed (h0=.[sha1(abc)]. h1=.[sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq)].).
  }
-
#
# Test Case #2 - Try standard test vectors from sha1.cpp.
#
&tr.tc002 test_sha1_fn=
  @if cand(
        strmatch([sha1(abc)], A9993E364706816ABA3E25717850C26C9CD0D89D),
        strmatch([sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)], 47B172810795699FE739197D1A1F5960700242F1),
        strmatch([sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)], 47B172810795699FE739197D1A1F5960700242F1),
        strmatch([sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq1234567)], 55A0C42A00BD4B496A16D1AC32E20B5A7FA3E087),
        strmatch([sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq12345678)], 9EF5C682D93914E77A5D345ABB957436445A6FB6)
      )=
  {
    @log smoke=TC002: Standard test vectors. Succeeded.
  },
  {
    @log smoke=TC002: Standard test vectors. Failed (h0=.[sha1(abc)]. h1=.[sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)]. h2=.[sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)]. h3=.[sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq1234567)]. h4=.[sha1(abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq12345678)].).
  }
-
#
# Test Case #3 - Try parser-related tests.
#
&tr.tc003 test_sha1_fn=
  @if cand(
        strmatch([sha1()], DA39A3EE5E6B4B0D3255BFEF95601890AFD80709),
        strmatch([sha1(abc,def)], B9C58B99E102D8B50B76D23E71E9C155E5C3195F)
      )=
  {
    @log smoke=TC003: Parser-related tests. Succeeded.;
    @trig me/tr.done
  },
  {
    @log smoke=TC003: Parser-related tests. Failed (h0=.[sha1()]. h1=.[sha1(abc,def)].).;
    @trig me/tr.done
  }
-
&tr.done test_sha1_fn=
  @log smoke=End sha1() test cases.;
  @notify smoke
-
drop test_sha1_fn
-
#
# End of Test Cases
#
