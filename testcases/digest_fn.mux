#
# digest_fn.mux - Test Cases for digest().
#
# Strategy: Exercise examples and test vectors.
#
@create test_digest_fn
-
@set test_digest_fn=INHERIT QUIET
-
#
# Beginning of Test Cases
#
&tr.tc000 test_digest_fn=
  @log smoke=Beginning digest() test cases.
-
#
# Test Case #1 - Test that help topic examples work.
#
&tr.tc001 test_digest_fn=
  @if strmatch([digest()],*NOT FOUND)=
  {
    @log smoke=TC001: DIGEST() is not supported on this version. Okay.
  },
  {
    @if cand(
        strmatch([digest(sha1,abc)], A9993E364706816ABA3E25717850C26C9CD0D89D),
        strmatch([digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq)], 84983E441C3BD26EBAAE4AA1F95129E5E54670F1)
      )=
    {
      @log smoke=TC001: Examples. Succeeded.
    },
    {
      @log smoke=TC001: Examples. Failed (h0=.[digest(sha1,abc)]. h1=.[digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq)].).
    }
  }
-
#
# Test Case #2 - Try standard test vectors from sha1.cpp.
#
&tr.tc002 test_digest_fn=
  @if strmatch([digest()],*NOT FOUND)=
  {
    @log smoke=TC002: DIGEST() is not supported on this version. Okay.
  },
  {
    @if cand(
        strmatch([digest(sha1,abc)], A9993E364706816ABA3E25717850C26C9CD0D89D),
        strmatch([digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)], 47B172810795699FE739197D1A1F5960700242F1),
        strmatch([digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)], 47B172810795699FE739197D1A1F5960700242F1),
        strmatch([digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq1234567)], 55A0C42A00BD4B496A16D1AC32E20B5A7FA3E087),
        strmatch([digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq12345678)], 9EF5C682D93914E77A5D345ABB957436445A6FB6)
      )=
    {
      @log smoke=TC002: Standard test vectors. Succeeded.
    },
    {
      @log smoke=TC002: Standard test vectors. Failed (h0=.[digest(sha1,abc)]. h1=.[digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)]. h2=.[digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnop)]. h3=.[digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq1234567)]. h4=.[digest(sha1,abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq12345678)].).
    }
  }
-
#
# Test Case #3 - Try parser-related tests.
#
&tr.tc003 test_digest_fn=
  @if strmatch([digest()],*NOT FOUND)=
  {
    @log smoke=TC003: DIGEST() is not supported on this version. Okay.
  },
  {
    @if cand(
        strmatch([digest(sha1)], DA39A3EE5E6B4B0D3255BFEF95601890AFD80709),
        strmatch([digest(sha1,)], DA39A3EE5E6B4B0D3255BFEF95601890AFD80709),
        strmatch([digest(sha1,abc,def)], B9C58B99E102D8B50B76D23E71E9C155E5C3195F)
      )=
    {
      @log smoke=TC003: Parser-related tests. Succeeded.
    },
    {
      @log smoke=TC003: Parser-related tests. Failed (h0=.[digest(sha1)]. h1=.[digest(sha1,)]. h2=.[digest(sha1,abc,def)].).
    }
  }
-
#
# Test Case #4 - Test MD5 is available.
#
&tr.tc004 test_digest_fn=
  @if strmatch([digest()],*NOT FOUND)=
  {
    @log smoke=TC005: DIGEST() is not supported on this version. Okay.;
    @trig me/tr.done
  },
  {
    @if digest(md5)=
    {
      @if cand(
        strmatch([digest(md5,)], D41D8CD98F00B204E9800998ECF8427E),
        strmatch([digest(md5,a)], 0CC175B9C0F1B6A831C399E269772661),
        strmatch([digest(md5,abc)], 900150983CD24FB0D6963F7D28E17F72),
        strmatch([digest(md5,message digest)], F96B697D7CB7938D525A2F31AAF161D0),
        strmatch([digest(md5,abcdefghijklmnopqrstuvwxyz)], C3FCD3D76192E4007DFB496CCA67E13B),
        strmatch([digest(md5,ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789)], D174AB98D277D9F5A5611C2C9F419D9F),
        strmatch([digest(md5,12345678901234567890123456789012345678901234567890123456789012345678901234567890)], 57EDF4A22BE3C955AC49DA2E2107B67A)
      )=
      {
        @log smoke=TC004: MD5 test vectors. Succeeded.;
        @trig me/tr.done
      },
      {
        @log smoke=TC004: MD5 test vectors. Failed (h0=.[digest(md5,)]. h1=.[digest(md5,a)]. h2=.[digest(md5,abc)]. h3=.[digest(md5,message digest)]. h4=.[digest(md5,abcdefghijklmnopqrstuvwxyz)]. h5=.[digest(md5,ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789)]. h6=.[digest(md5,12345678901234567890123456789012345678901234567890123456789012345678901234567890)].).;
        @trig me/tr.done
      }
    },
    {
      @log smoke=TC004: MD5 is not supported in this version. Okay.;
      @trig me/tr.done
    }
  }
-
&tr.done test_digest_fn=
  @log smoke=End digest() test cases.;
  @notify smoke
-
drop test_digest_fn
-
#
# End of Test Cases
#
