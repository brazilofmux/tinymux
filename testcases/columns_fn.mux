&tr.tc004 test_columns_fn=
  @if cand(
        strmatch(.[columns(a b c d e f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(%ba b c d e f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
