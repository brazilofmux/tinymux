        strmatch(.[columns(a%b%bb c d e f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b%b%bc d e f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c%b%bd e f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d%b%be f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d e%b%bf g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d e f%b%bg h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d e f g%b%bh,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d e f g h%b%b,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.)
