        strmatch(.[columns(a b c%bd e f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d%be f g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d e%bf g h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
        strmatch(.[columns(a b c d e f%bg h,5)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.),
