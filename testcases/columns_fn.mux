#
# Test Case #5 - Vary number of elements with single hyphen delimiter.
#
&tr.tc005 test_columns_fn=
  @if cand(
        strmatch(.[columns(,5,-)]., ..),
        strmatch(.[columns(-,5,-)]., .%b%b%b%b%b%b%b%b%b%b%r.),
        strmatch(.[columns(a,5,-)]., .a%b%b%b%b%r.),
        strmatch(.[columns(a-b,5,-)]., .a%b%b%b%bb%b%b%b%b%r.),
        strmatch(.[columns(a-b-c,5,-)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%b%r.),
        strmatch(.[columns(a-b-c-d,5,-)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%b%r.),
        strmatch(.[columns(a-b-c-d-e,5,-)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%b%r.),
        strmatch(.[columns(a-b-c-d-e-f,5,-)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%b%r.),
        strmatch(.[columns(a-b-c-d-e-f-g,5,-)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%b%r.),
        strmatch(.[columns(a-b-c-d-e-f-g-h,5,-)]., .a%b%b%b%bb%b%b%b%bc%b%b%b%bd%b%b%b%be%b%b%b%bf%b%b%b%bg%b%b%b%bh%b%b%b%b%r.)
      )=

  {
    @log smoke=TC005: columns vary elements with single-hyphen delimiter. Succeeded.
  },
  {
    @log smoke=TC005: columns vary elements with single-hypehn delimiter Failed.;
    @log smoke=TC005 actual L0 =.[columns(,5,-)]=.;
    @log smoke=TC005 actual L1 =.[columns(-,5,-)]=.;
    @log smoke=TC005 actual L2 =.[columns(a,5,-)]=.;
    @log smoke=TC005 actual L3 =.[columns(a-b,5,-)]=.;
    @log smoke=TC005 actual L4 =.[columns(a-b-c,5,-)]=.;
    @log smoke=TC005 actual L5 =.[columns(a-b-c-d,5,-)]=.;
    @log smoke=TC005 actual L6 =.[columns(a-b-c-d-e,5,-)]=.;
    @log smoke=TC005 actual L7 =.[columns(a-b-c-d-e-f,5,-)]=.;
    @log smoke=TC005 actual L8 =.[columns(a-b-c-d-e-f-g,5,-)]=.;
    @log smoke=TC005 actual L9 =.[columns(a-b-c-d-e-f-g-h,5,-)]=.
  }
-
#
# Test Case #6 - Walk two elements through single-hyphens.
#
&tr.tc006 test_columns_fn=
  @if cand(
        strmatch(.[columns(---,5,-)]., .%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%r.),
        strmatch(.[columns(b---,5,-)]., .b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%b%r.),
        strmatch(.[columns(-b--,5,-)]., .%b%b%b%b%bb%b%b%b%b%b%b%b%b%b%b%b%b%b%b%r.),
        strmatch(.[columns(a--b-,5,-)]., .a%b%b%b%b%b%b%b%b%bb%b%b%b%b%b%b%b%b%b%r.),
        strmatch(.[columns(-a--b,5,-)]., .%b%b%b%b%ba%b%b%b%b%b%b%b%b%bb%b%b%b%b%r.),
        strmatch(.[columns(--a-,5,-)]., .%b%b%b%b%b%b%b%b%b%ba%b%b%b%b%b%b%b%b%b%r.),
        strmatch(.[columns(---a,5,-)]., .%b%b%b%b%b%b%b%b%b%b%b%b%b%b%ba%b%b%b%b%r.)
      )=

  {
    @log smoke=TC006: columns walk two elements through single-hyphens. Succeeded.
  },
  {
    @log smoke=TC006: columns walk two elements through single-hyphens Failed.;
    @log smoke=TC006 actual L0 =.[columns(---,5,-)]=.;
    @log smoke=TC006 actual L1 =.[columns(b---,5,-)]=.;
    @log smoke=TC006 actual L2 =.[columns(-b--,5,-)]=.;
    @log smoke=TC006 actual L3 =.[columns(a--b-,5,-)]=.;
    @log smoke=TC006 actual L4 =.[columns(-a--b,5,-)]=.;
    @log smoke=TC006 actual L5 =.[columns(--a-,5,-)]=.;
    @log smoke=TC006 actual L6 =.[columns(---a,5,-)]=.
  }
-
