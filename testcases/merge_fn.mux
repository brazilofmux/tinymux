#
# Test Case #14 - Behavior and edge cases: replace at every matching position,
# at a single position, a no-op when the merge character is absent, and the
# equal-length requirement.
#
&tr.tc014 test_merge_fn=
  @if cand(
        strmatch(merge(00000,abcde,0), abcde),
        strmatch(merge(01234,abcde,0), a1234),
        strmatch(merge(abcde,XXXXX,c), abXde),
        strmatch(merge(a,b,x), a),
        strmatch(merge(abc,de,a), #-1*)
      )=
  {
    @log smoke=TC014: merge behavior and edge cases. Succeeded.;
    @trig me/tr.done
  },
  {
    @log smoke=TC014: merge behavior and edge cases. Failed (all=[merge(00000,abcde,0)] one=[merge(01234,abcde,0)] mid=[merge(abcde,XXXXX,c)] noop=[merge(a,b,x)] err=[merge(abc,de,a)]).;
    @trig me/tr.done
  }
-
&tr.done test_merge_fn=
  @log smoke=End merge() test cases.;
  @notify smoke
-
drop test_merge_fn
-
#
# End of Test Cases
#
