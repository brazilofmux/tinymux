    @if cand(
          strmatch(merge([chr(65296)][chr(65297)][chr(65298)][chr(65299)][chr(65300)],[chr(65345)][chr(65346)][chr(65347)][chr(65348)][chr(65349)],[chr(65296)]), [chr(65345)][chr(65297)][chr(65298)][chr(65299)][chr(65300)]),
