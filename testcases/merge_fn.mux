          strmatch(merge([chr(65297)][chr(65298)][chr(65299)][chr(65296)][chr(65296)],[chr(65345)][chr(65346)][chr(65347)][chr(65348)][chr(65349)],[chr(65296)]), [chr(65297)][chr(65298)][chr(65299)][chr(65348)][chr(65349)]),
          strmatch(merge([chr(65297)][chr(65298)][chr(65299)][chr(65300)][chr(65296)],[chr(65345)][chr(65346)][chr(65347)][chr(65348)][chr(65349)],[chr(65296)]), [chr(65297)][chr(65298)][chr(65299)][chr(65300)][chr(65349)])
        )=
    {
      @log smoke=TC010: Vary length of run over 5 character Unicode string. Succeeded.
    },
    {
      @log smoke=TC010: Vary length of run over 5 character Unicode string. Failed (r1=[merge([chr(65296)][chr(65297)][chr(65298)][chr(65299)][chr(65300)],[chr(65345)][chr(65346)][chr(65347)][chr(65348)][chr(65349)],[chr(65296)])] r5=[merge([chr(65296)][chr(65296)][chr(65296)][chr(65296)][chr(65296)],[chr(65345)][chr(65346)][chr(65347)][chr(65348)][chr(65349)],[chr(65296)])]).
    }
  },
  {
    @log smoke=TC010: Unicode is not supported on this version. Okay.
