#
# convtime_fn.mux - Test Cases for convtime().
#
# Strategy: The structure of the code under convtime() can be broken into the
# core Gregorian routines, the timezone routines, and the auto-magic date
# string parser. Of these three, the timezone routines have proven the most
# fragile of the three as it is the most affected by 32/64-bit, compiler, and
# Operating System variations.
#
# The first battery of test cases attempt to cover the core Gregorian routines
# and bypass paths that would lead to timezone adjustments or the more powerful
# date string parser.
#
# Another batch will use convtime() and convsecs() as a pair.
#
# Another batch of test cases will validate that timezone adjustments is
# reasonable. This is tricky because the server that runs these tests could
# potentially be in any timezone.
#
# Finally, the last batch of cases will attempt to cover general-case date
# string parser.
#
@create test_convtime_fn
-
@set test_convtime_fn=INHERIT QUIET
-
#
# Beginning of Test Cases
#
&tr.tc000 test_convtime_fn=
  @log smoke=Beginning convtime() test cases.
-
#
# Test Case #1 - Calendar invariants for 2006: the Jan 1 anchor
# epoch, every month-boundary delta (Feb has 28 days), the one-day
# step, and an exact interior timestamp.
#
&tr.tc001 test_convtime_fn=
  @if cand(
        eq(convtime(jan 1 00:00:00 2006,utc), 1136073600),
        eq(sub(convtime(feb 1 00:00:00 2006,utc), convtime(jan 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(mar 1 00:00:00 2006,utc), convtime(feb 1 00:00:00 2006,utc)), 2419200),
        eq(sub(convtime(apr 1 00:00:00 2006,utc), convtime(mar 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(may 1 00:00:00 2006,utc), convtime(apr 1 00:00:00 2006,utc)), 2592000),
        eq(sub(convtime(jun 1 00:00:00 2006,utc), convtime(may 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(jul 1 00:00:00 2006,utc), convtime(jun 1 00:00:00 2006,utc)), 2592000),
        eq(sub(convtime(aug 1 00:00:00 2006,utc), convtime(jul 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(sep 1 00:00:00 2006,utc), convtime(aug 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(oct 1 00:00:00 2006,utc), convtime(sep 1 00:00:00 2006,utc)), 2592000),
        eq(sub(convtime(nov 1 00:00:00 2006,utc), convtime(oct 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(dec 1 00:00:00 2006,utc), convtime(nov 1 00:00:00 2006,utc)), 2592000),
        eq(sub(convtime(jan 1 00:00:00 2007,utc), convtime(dec 1 00:00:00 2006,utc)), 2678400),
        eq(sub(convtime(jan 2 00:00:00 2006,utc), convtime(jan 1 00:00:00 2006,utc)), 86400),
        eq(convtime(jul 15 12:30:45 2006,utc), 1152966645)
      )=
  {
    @log smoke=TC001: convtime invariants for 2006. Succeeded.
  },
  {
    @log smoke=TC001: convtime invariants for 2006. Failed (anchor=[convtime(jan 1 00:00:00 2006,utc)] feb=[convtime(feb 1 00:00:00 2006,utc)] mar=[convtime(mar 1 00:00:00 2006,utc)] jul15=[convtime(jul 15 12:30:45 2006,utc)] nextjan=[convtime(jan 1 00:00:00 2007,utc)]).
  }
-
#
# Test Case #2 - Calendar invariants for 1970: the Jan 1 anchor
# epoch, every month-boundary delta (Feb has 28 days), the one-day
# step, and an exact interior timestamp.
#
&tr.tc002 test_convtime_fn=
  @if cand(
        eq(convtime(jan 1 00:00:00 1970,utc), 0),
        eq(sub(convtime(feb 1 00:00:00 1970,utc), convtime(jan 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(mar 1 00:00:00 1970,utc), convtime(feb 1 00:00:00 1970,utc)), 2419200),
        eq(sub(convtime(apr 1 00:00:00 1970,utc), convtime(mar 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(may 1 00:00:00 1970,utc), convtime(apr 1 00:00:00 1970,utc)), 2592000),
        eq(sub(convtime(jun 1 00:00:00 1970,utc), convtime(may 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(jul 1 00:00:00 1970,utc), convtime(jun 1 00:00:00 1970,utc)), 2592000),
        eq(sub(convtime(aug 1 00:00:00 1970,utc), convtime(jul 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(sep 1 00:00:00 1970,utc), convtime(aug 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(oct 1 00:00:00 1970,utc), convtime(sep 1 00:00:00 1970,utc)), 2592000),
        eq(sub(convtime(nov 1 00:00:00 1970,utc), convtime(oct 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(dec 1 00:00:00 1970,utc), convtime(nov 1 00:00:00 1970,utc)), 2592000),
        eq(sub(convtime(jan 1 00:00:00 1971,utc), convtime(dec 1 00:00:00 1970,utc)), 2678400),
        eq(sub(convtime(jan 2 00:00:00 1970,utc), convtime(jan 1 00:00:00 1970,utc)), 86400),
        eq(convtime(jul 15 12:30:45 1970,utc), 16893045)
      )=
  {
    @log smoke=TC002: convtime invariants for 1970. Succeeded.
  },
  {
    @log smoke=TC002: convtime invariants for 1970. Failed (anchor=[convtime(jan 1 00:00:00 1970,utc)] feb=[convtime(feb 1 00:00:00 1970,utc)] mar=[convtime(mar 1 00:00:00 1970,utc)] jul15=[convtime(jul 15 12:30:45 1970,utc)] nextjan=[convtime(jan 1 00:00:00 1971,utc)]).
  }
-
#
# Test Case #3 - Calendar invariants for 1969: the Jan 1 anchor
# epoch, every month-boundary delta (Feb has 28 days), the one-day
# step, and an exact interior timestamp.
#
&tr.tc003 test_convtime_fn=
  @if cand(
        eq(convtime(jan 1 00:00:00 1969,utc), -31536000),
        eq(sub(convtime(feb 1 00:00:00 1969,utc), convtime(jan 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(mar 1 00:00:00 1969,utc), convtime(feb 1 00:00:00 1969,utc)), 2419200),
        eq(sub(convtime(apr 1 00:00:00 1969,utc), convtime(mar 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(may 1 00:00:00 1969,utc), convtime(apr 1 00:00:00 1969,utc)), 2592000),
        eq(sub(convtime(jun 1 00:00:00 1969,utc), convtime(may 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(jul 1 00:00:00 1969,utc), convtime(jun 1 00:00:00 1969,utc)), 2592000),
        eq(sub(convtime(aug 1 00:00:00 1969,utc), convtime(jul 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(sep 1 00:00:00 1969,utc), convtime(aug 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(oct 1 00:00:00 1969,utc), convtime(sep 1 00:00:00 1969,utc)), 2592000),
        eq(sub(convtime(nov 1 00:00:00 1969,utc), convtime(oct 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(dec 1 00:00:00 1969,utc), convtime(nov 1 00:00:00 1969,utc)), 2592000),
        eq(sub(convtime(jan 1 00:00:00 1970,utc), convtime(dec 1 00:00:00 1969,utc)), 2678400),
        eq(sub(convtime(jan 2 00:00:00 1969,utc), convtime(jan 1 00:00:00 1969,utc)), 86400),
        eq(convtime(jul 15 12:30:45 1969,utc), -14642955)
      )=
  {
    @log smoke=TC003: convtime invariants for 1969. Succeeded.
  },
  {
    @log smoke=TC003: convtime invariants for 1969. Failed (anchor=[convtime(jan 1 00:00:00 1969,utc)] feb=[convtime(feb 1 00:00:00 1969,utc)] mar=[convtime(mar 1 00:00:00 1969,utc)] jul15=[convtime(jul 15 12:30:45 1969,utc)] nextjan=[convtime(jan 1 00:00:00 1970,utc)]).
  }
-
#
# Test Case #4 - Calendar invariants for 1601: the Jan 1 anchor
