&tr.tc004 test_convtime_fn=
  @if cand(
        eq(convtime(jan 1 00:00:00 1601,utc), -11644473600),
        eq(sub(convtime(feb 1 00:00:00 1601,utc), convtime(jan 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(mar 1 00:00:00 1601,utc), convtime(feb 1 00:00:00 1601,utc)), 2419200),
        eq(sub(convtime(apr 1 00:00:00 1601,utc), convtime(mar 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(may 1 00:00:00 1601,utc), convtime(apr 1 00:00:00 1601,utc)), 2592000),
        eq(sub(convtime(jun 1 00:00:00 1601,utc), convtime(may 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(jul 1 00:00:00 1601,utc), convtime(jun 1 00:00:00 1601,utc)), 2592000),
        eq(sub(convtime(aug 1 00:00:00 1601,utc), convtime(jul 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(sep 1 00:00:00 1601,utc), convtime(aug 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(oct 1 00:00:00 1601,utc), convtime(sep 1 00:00:00 1601,utc)), 2592000),
        eq(sub(convtime(nov 1 00:00:00 1601,utc), convtime(oct 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(dec 1 00:00:00 1601,utc), convtime(nov 1 00:00:00 1601,utc)), 2592000),
        eq(sub(convtime(jan 1 00:00:00 1602,utc), convtime(dec 1 00:00:00 1601,utc)), 2678400),
        eq(sub(convtime(jan 2 00:00:00 1601,utc), convtime(jan 1 00:00:00 1601,utc)), 86400),
        eq(convtime(jul 15 12:30:45 1601,utc), -11627580555)
      )=
