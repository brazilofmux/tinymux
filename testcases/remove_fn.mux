#
# remove_fn.mux - Test Cases for remove().
#
@create test_remove_fn
-
@set test_remove_fn=INHERIT QUIET
-
#
# Beginning of Test Cases
#
&tr.tc000 test_remove_fn=
  @log smoke=Beginning remove() test cases.
-
#
# Test Case #1 - Basic list element removal.
#
&tr.tc001 test_remove_fn=
  @if cand(
        strmatch(remove(a b c d,c), a b d),
        strmatch(remove(a|b|c,b,|), a|c)
      )=
  {
    @log smoke=TC001: remove basic operations. Succeeded.
  },
  {
    @log smoke=TC001: remove basic operations. Failed (remove(c)=[remove(a b c d,c)] remove(b%,|)=[remove(a|b|c,b,|)]).;
  }
-
#
# Test Case #2 - Repeats, misses, and empty input.
#
&tr.tc002 test_remove_fn=
  think setq(0,remove(a b a c,a));
  think setq(1,remove(a b c,x));
  think setq(2,remove(,a));
  think setq(3,remove(a|b|a|c,a,|));
  @if cand(
        eq(words(%q0),3),
        strmatch(first(%q0),b),
        eq(match(%q0,a),2),
        strmatch(last(%q0),c),
        eq(words(%q1),3),
        strmatch(first(%q1),a),
        strmatch(last(%q1),c),
        eq(strlen(%q2),0),
        eq(words(%q3,|),3),
        strmatch(extract(%q3,1,1,|),b),
        strmatch(extract(%q3,2,1,|),a),
        strmatch(extract(%q3,3,1,|),c)
      )=
  {
    @log smoke=TC002: remove repeat and miss cases. Succeeded.
  },
  {
    @log smoke=TC002: remove repeat and miss cases. Failed (q0=%q0 q1=%q1 q2=%q2 q3=%q3).
  }
-
#
# Test Case #3 - Error path: element contains active separator.
#
&tr.tc003 test_remove_fn=
  @if cand(
        strmatch(remove(a b c d,b c), #-1 CAN ONLY REMOVE ONE ELEMENT),
        strmatch(remove(a,a b), #-1 CAN ONLY REMOVE ONE ELEMENT),
        strmatch(remove(a b c,a b,%b), #-1 CAN ONLY REMOVE ONE ELEMENT),
        strmatch(remove(a|b|c,b c,|), a|b|c)
      )=
  {
    @log smoke=TC003: remove() error path. Succeeded.;
    @trig me/tr.done
  },
  {
    @log smoke=TC003: remove() error path. Failed (default=[remove(a b c d,b c)] trivial=[remove(a,a b)] explicit=[remove(a b c,a b,%b)] pipe=[remove(a|b|c,b c,|)]).;
    @trig me/tr.done
  }
-
&tr.done test_remove_fn=
  @log smoke=End remove() test cases.;
  @notify smoke
-
drop test_remove_fn
-
#
# End of Test Cases
#
