	-rm -f ./$(DEPDIR)/netmux-net.Po
	-rm -f ./$(DEPDIR)/netmux-netaddr.Po
	-rm -f ./$(DEPDIR)/netmux-signals.Po
	-rm -f ./$(DEPDIR)/netmux-sitemon.Po
	-rm -f ./$(DEPDIR)/netmux-telnet.Po
	-rm -f ./$(DEPDIR)/netmux-version.Po
	-rm -f ./$(DEPDIR)/netmux-websocket.Po
	-rm -f ./$(DEPDIR)/slave.Po
	-rm -f ./$(DEPDIR)/stubslave.Po
	-rm -f Makefile
distclean-am: clean-am distclean-compile distclean-generic \
	distclean-tags

