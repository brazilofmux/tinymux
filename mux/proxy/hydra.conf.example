# Hydra configuration example
#
# Copy to hydra.conf and edit for your deployment.

# --- Network listeners ---
# listen <type> <host:port> [cert=<path> key=<path>]
#
# Types: telnet, telnet+tls, websocket, websocket+tls, grpc-web
listen telnet+tls   0.0.0.0:4202 cert=hydra.pem key=hydra.key
# listen telnet       0.0.0.0:4201
# listen websocket    0.0.0.0:4203
# listen grpc-web     0.0.0.0:4205

# --- Front-door TLS policy ---
# By default, plaintext (non-TLS) front-door connections are rejected.
# Set to 'yes' to allow plaintext telnet (e.g. for SSH+TF users).
# Note: credential commands (create, /addcred) always require TLS
# regardless of this setting.
# allow_plaintext no

# --- CORS (for grpc-web listeners) ---
# Allowed origins for cross-origin requests.  Repeat for multiple origins.
# Default: deny all.  Use '*' to allow any origin (not recommended).
# cors_origin https://your-web-client.example.com

# --- gRPC native (optional, requires --enable-grpc at build time) ---
# grpc_listen 0.0.0.0:4204

# --- Database ---
database hydra.sqlite

# --- Master key (for game credential encryption) ---
#
# The master key encrypts stored game login credentials (auto-login).
# Without it, credential storage and auto-login are disabled.
#
# Three ways to provide the key (checked in this order):
#
# 1. Environment variable (preferred for containers/systemd):
#    export HYDRA_MASTER_KEY=<64 hex chars>
#
# 2. File path (32 raw bytes, mode 0600):
#    master_key /etc/hydra/master.key
#
# 3. Auto-generate: if master_key is set but the file doesn't exist,
#    Hydra generates a new key and saves it with mode 0600.
#
master_key master.key

# --- Session defaults ---
scrollback_lines            10000
session_idle_timeout        86400
detached_session_timeout    86400
link_reconnect_timeout      300

# --- Resource limits ---
max_sessions_per_account    1
max_frontdoors_per_session  3
max_links_per_session       5
max_scrollback_memory_mb    64
max_connections_per_ip      10
connect_rate_limit          5
failed_login_lockout        5
failed_login_lockout_minutes 5

# --- Logging ---
log_file hydra.log
log_level info

# --- Games ---
game "LocalMUX" {
    host            localhost
    port            2860
    transport       tcp
    type            local
    binary          /home/user/tinymux/mux/game/bin/netmux
    workdir         /home/user/tinymux/mux/game
    autostart       no
    reconnect       yes
    retry           5s 10s 30s 60s
    charset         utf-8
    # Back-door TLS is required by default. Set to 'no' for games on
    # localhost or the same VPC that don't support TLS.
    tls_required    no
}

# game "RemoteMUD" {
#     host        mud.example.com
#     port        4000
#     type        remote
#     tls         yes
#     tls_verify  yes
#     # tls_ca    /etc/ssl/certs/ca-certificates.crt
