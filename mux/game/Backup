#!/bin/sh
#
#   Backup - Create a timestamped backup of the SQLite database.
#
#   Safe to run while the server is live. Uses SQLite's .backup
#   command which handles WAL correctly.
#
PATH=/bin:/usr/bin:/usr/local/bin:.; export PATH
#
. mux.config
#
DBDATE=$(date +%m%d-%H%M)
SQLITE_DB=$DATA/$GAMENAME.sqlite
BACKUP_DB=$DATA/$GAMENAME.$DBDATE.sqlite

if [ ! -r "$SQLITE_DB" ]; then
    echo "No database found at $SQLITE_DB"
    exit 1
fi

echo "Backing up $SQLITE_DB to $BACKUP_DB..."
sqlite3 "$SQLITE_DB" ".backup '$BACKUP_DB'"

if [ -r "$BACKUP_DB" ]; then
    # Optionally compress the backup
    gzip -9 "$BACKUP_DB"
    echo "Backup complete: ${BACKUP_DB}.gz"
else
    echo "Backup failed."
    exit 1
fi
